@page "/products"
@rendermode InteractiveServer

@using BlazorWebAppCRUDServer.Services
@inject IProductService ProductService

<h3>Products</h3>
<a class="btn btn-primary mb-3" href="/products/create">Add New</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>
                <button class="btn btn-link p-0" @onclick='() => SortBy("Name")'>
                    Name
                    @(CurrentSortBy == "Name"
                        ? (CurrentSortDirection == "asc" ? "▲" : "▼")
                        : "↕")
                </button>
            </th>

            <th>
                <button class="btn btn-link p-0" @onclick='() => SortBy("Description")'>
                    Description
                    @(CurrentSortBy == "Description"
                        ? (CurrentSortDirection == "asc" ? "▲" : "▼")
                        : "↕")
                </button>
            </th>

            <th>
                <button class="btn btn-link p-0" @onclick='() => SortBy("Price")'>
                    Price
                    @(CurrentSortBy == "Price"
                        ? (CurrentSortDirection == "asc" ? "▲" : "▼")
                        : "↕")
                </button>
            </th>

            <th>
                <button class="btn btn-link p-0" @onclick='() => SortBy("Quantity")'>
                    Quantity
                    @(CurrentSortBy == "Quantity"
                        ? (CurrentSortDirection == "asc" ? "▲" : "▼")
                        : "↕")
                </button>
            </th>

            <th></th>
        </tr>
    </thead>

    <tbody>
        @if (Products is not null)
        {
            @foreach (var p in Products)
            {
                <tr>
                    <td>@p.Name</td>
                    <td>@p.Description</td>
                    <td>@p.Price</td>
                    <td>@p.Quantity</td>
                    <td>
                        <a class="btn btn-sm btn-primary" href="/products/edit/@p.Id">Edit</a>
                        <a class="btn btn-sm btn-danger ms-2" href="/products/delete/@p.Id">Delete</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<!-- Pagination UI -->
<div class="pagination-controls mt-3">
    <button class="btn btn-secondary"
            @onclick="PreviousPage"
            disabled="@IsFirstPage">
        Previous
    </button>

    <span class="mx-2">
        Page @CurrentPage of @TotalPages
    </span>

    <button class="btn btn-secondary"
            @onclick="NextPage"
            disabled="@IsLastPage">
        Next
    </button>
</div>

@code {

    // -------------------------
    // State
    // -------------------------
    private int CurrentPage = 1;
    private int PageSize = 10;
    private int TotalCount = 0;

    private string CurrentSortBy = "Name";
    private string CurrentSortDirection = "asc";

    private List<Product> Products = new();

    // -------------------------
    // Lifecycle
    // -------------------------
    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    // -------------------------
    // Centralized loader
    // -------------------------
    private async Task LoadProducts()
    {
        Products = await ProductService.GetProductsAsync(
            CurrentSortBy,
            CurrentSortDirection,
            CurrentPage,
            PageSize
        );

        TotalCount = await ProductService.GetTotalCountAsync();
    }

    // -------------------------
    // Sorting
    // -------------------------
    private async Task SortBy(string column)
    {
        if (CurrentSortBy == column)
        {
            CurrentSortDirection = CurrentSortDirection == "asc" ? "desc" : "asc";
        }
        else
        {
            CurrentSortBy = column;
            CurrentSortDirection = "asc";
        }

        CurrentPage = 1;
        await LoadProducts();
    }

    // -------------------------
    // Pagination Helpers
    // -------------------------
    private int TotalPages => (int)Math.Ceiling((double)TotalCount / PageSize);
    private bool IsFirstPage => CurrentPage == 1;
    private bool IsLastPage => CurrentPage == TotalPages;

    // -------------------------
    // Pagination Actions
    // -------------------------
    private async Task NextPage()
    {
        if (!IsLastPage)
        {
            CurrentPage++;
            await LoadProducts();
        }
    }

    private async Task PreviousPage()
    {
        if (!IsFirstPage)
        {
            CurrentPage--;
            await LoadProducts();
        }
    }

}   